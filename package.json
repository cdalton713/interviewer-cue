{
  "name": "granola-interviewer",
  "private": true,
  "type": "module",
  "bin": {
    "granola-interviewer": "./dist/app.js",
    "granola-decrypt-cache": "./dist/cli/decrypt.js",
    "granola-watch-cache": "./dist/cli/watch.js"
  },
  "scripts": {
    "dev": "tsx src/app.tsx",
