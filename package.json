{
  "name": "interviewer-cue",
  "version": "0.1.4",
  "description": "Terminal interview cue assistant with Granola transcript integration.",
  "license": "MIT",
  "author": "Christian Dalton",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdalton713/interviewer-cue.git"
  },
  "bugs": {
    "url": "https://github.com/cdalton713/interviewer-cue/issues"
  },
  "homepage": "https://github.com/cdalton713/interviewer-cue#readme",
  "type": "module",
  "bin": {
    "interviewer-cue": "./dist/cli/interviewer-cue.js"
  },
  "files": [
    "dist",
    "fixtures/simulation/technical-interview.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/app.tsx",
    "dev:simulation": "tsx src/app.tsx --transcript-source simulation --simulation-url tcp://127.0.0.1:4767",
    "simulate": "tsx src/cli/simulate-transcript.ts",
    "cli:decrypt": "tsx src/cli/decrypt.ts",
    "cli:watch": "tsx src/cli/watch.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "pack:dry-run": "npm pack --dry-run",
    "release:dry-run": "node scripts/release.mjs --dry-run --publish",
    "release": "node scripts/release.mjs --publish",
    "release:patch": "node scripts/release.mjs patch --publish",
    "release:minor": "node scripts/release.mjs minor --publish",
    "release:major": "node scripts/release.mjs major --publish"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/google": "^3.0.72",
    "@ai-sdk/openai": "^3.0.63",
    "ai": "^6.0.177",
    "commander": "^14.0.3",
    "immer": "^11.1.8",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "use-immer": "^0.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.20",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
